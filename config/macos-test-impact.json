{
  "schemaVersion": 2,
  "defaultRequiredSuites": [],
  "defaultRequiredRuntimeChecks": [],
  "rules": [
    {
      "requiredSuites": ["benchmark"],
      "requiredRuntimeChecks": ["telemetry-overhead"],
      "patterns": [
        "third_party_patches/mlx-audio-swift/Package.swift",
        "third_party_patches/mlx-audio-swift/Sources/**",
        "third_party_patches/mlx-audio-swift/Tests/**",
        "Sources/QwenVoiceBackendCore/**",
        "Sources/QwenVoiceCore/GenerationTelemetryRecord.swift",
        "Sources/QwenVoiceCore/GenerationTelemetry.swift",
        "Sources/QwenVoiceCore/NativeStreamingSynthesisSession.swift",
        "Sources/VocelloCLI/BenchCommand.swift",
        "benchmarks/**",
        "scripts/summarize_generation_telemetry.py"
      ]
    },
    {
      "requiredSuites": ["full"],
      "requiredRuntimeChecks": [],
      "patterns": [
        "project.yml",
        "Sources/ViewModels/**",
        "Sources/Services/**",
        "Sources/QwenVoiceNative/**",
        "Sources/QwenVoiceEngineService/**",
        "Sources/QwenVoiceEngineSupport/**",
        "Sources/SharedSupport/**",
        "Sources/QwenVoiceCore/**",
        "config/macos-ui-scenarios.json",
        "config/backend-risk-spine.json",
        ".agents/skills/vocello-macos-ui-qa/**",
        "scripts/macos_agent_ui.sh",
        "scripts/lib/macos_agent_ui.py",
        "scripts/test_macos_agent_ui.py",
        "scripts/macos_test.sh",
        ".github/workflows/ci.yml"
      ]
    },
    {
      "requiredSuites": ["quick"],
      "requiredRuntimeChecks": [],
      "patterns": [
        "Sources/Views/**",
        "Sources/ContentView.swift",
        "Sources/QwenVoiceApp.swift",
        "Sources/Assets.xcassets/**",
        "Sources/Info.plist"
      ]
    }
  ]
}
